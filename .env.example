REPORT_URL=http://10.20.10.63/reports/powerbi/scrape?&rs:Embed=true
OUTPUT_DIR=output
LOG_DIR=logs
HEADLESS=true
BROWSER_CHANNEL=msedge
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
DEVICE_SCALE_FACTOR=2
NAVIGATION_TIMEOUT_MS=120000
REPORT_RENDER_TIMEOUT_MS=180000
REPORT_STABLE_INTERVAL_MS=2000
REPORT_STABLE_POLLS=3
POST_TAB_CLICK_WAIT_MS=5000
SCREENSHOT_PREFIX=pbirs
TIMEZONE=Africa/Lagos
EXPECTED_SHEETS=Home,Questions,Post,Response,Post reach,Spam

# Authentication modes:
#   none        -> no auth
#   basic       -> HTTP basic auth with HTTP_USERNAME / HTTP_PASSWORD
#   form        -> login form with PBIRS_USERNAME / PBIRS_PASSWORD
#   integrated  -> Windows integrated auth using the current account
AUTH_MODE=integrated
AUTH_SERVER_WHITELIST=10.20.10.63
EDGE_USER_DATA_DIR=
EDGE_PROFILE_DIRECTORY=
HTTP_USERNAME=
HTTP_PASSWORD=
PBIRS_USERNAME=
PBIRS_PASSWORD=
LOGIN_USERNAME_SELECTOR=
LOGIN_PASSWORD_SELECTOR=
LOGIN_SUBMIT_SELECTOR=

SMTP_HOST=smtp.example.local
SMTP_PORT=587
SMTP_TIMEOUT_SECONDS=300
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENVELOPE_FROM=
EMAIL_FROM=pbirs-bot@example.local
EMAIL_REPLY_TO=
EMAIL_TO=recipient1@example.local,recipient2@example.local
EMAIL_SUBJECT_PREFIX=PBIRS Daily Capture

SCHEDULE_TIME=08:00

# Slicer filtering settings (optional, leave blank to skip filtering)
FILTER_SLICER_NAME=
FILTER_SLICER_PAGE=
FILTER_EXCLUDE_OPTIONS=
SLICER_DROPDOWN_WAIT_MS=0
SLICER_APPLY_WAIT_MS=0
